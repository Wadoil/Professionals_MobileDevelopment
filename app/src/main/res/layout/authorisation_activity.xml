<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".Presentation.Authorization">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/raleway_bold"
        android:text="@string/welcome_message"
        android:textColor="@color/text"
        android:textSize="48sp"
        tools:layout_editor_absoluteX="88dp"
        tools:layout_editor_absoluteY="74dp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="@string/continue_with_sm_text"
        android:textColor="@color/hint"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="41dp"
        tools:layout_editor_absoluteY="181dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/raleway_medium"
        android:text="@string/Email"
        android:textColor="@color/text"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="41dp"
        tools:layout_editor_absoluteY="244dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="340dp"
        android:layout_height="56dp"
        app:boxBackgroundColor="#F5F5F7"
        app:boxBackgroundMode="outline"
        app:passwordToggleEnabled="false"
        tools:layout_editor_absoluteX="42dp"
        tools:layout_editor_absoluteY="290dp">


        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="335dp"
            android:layout_height="49dp"
            android:backgroundTint="#F5F5F7"
            android:fontFamily="@font/raleway_medium"
            android:hint="@string/email_hint"
            android:password="false"
            android:singleLine="false"
            android:textColor="@color/hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="349dp"
        android:layout_height="66dp"
        app:boxBackgroundColor="#F5F5F7"
        app:passwordToggleEnabled="true"
        tools:layout_editor_absoluteX="42dp"
        tools:layout_editor_absoluteY="406dp">

        <EditText
            android:id="@+id/editTextTextPassword2"
            android:layout_width="339dp"
            android:layout_height="49dp"
            android:layout_weight="1"
            android:ems="10"
            android:fontFamily="@font/raleway_medium"
            android:hint="@string/password_hint"
            android:inputType="textPassword"
            android:textSize="24sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/raleway_medium"
        android:text="@string/Password"
        android:textColor="@color/text"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="41dp"
        tools:layout_editor_absoluteY="360dp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="@string/fill_data_text"
        android:textColor="@color/hint"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="110dp"
        tools:layout_editor_absoluteY="150dp" />

    <Button
        android:id="@+id/button2"
        android:layout_width="335dp"
        android:layout_height="55dp"
        android:backgroundTint="@color/button_cyan"
        android:onClick="onLoginButtonClick"
        android:text="@string/Log_in"
        android:textColor="@color/SubTextLight"
        tools:layout_editor_absoluteX="47dp"
        tools:layout_editor_absoluteY="581dp" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="@string/recover"
        android:textColor="@color/SubTextDark"
        tools:layout_editor_absoluteX="252dp"
        tools:layout_editor_absoluteY="472dp" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/raleway_medium"
        android:text="@string/create_user"
        android:textColor="@color/text"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="208dp"
        tools:layout_editor_absoluteY="672dp" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/raleway_medium"
        android:text="@string/first_time"
        android:textColor="@color/text"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="92dp"
        tools:layout_editor_absoluteY="672dp" />

</androidx.constraintlayout.widget.ConstraintLayout>